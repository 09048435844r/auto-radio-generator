#!/usr/bin/env python
"""Git pre-commit hook: run pytest before allowing commit."""

from datetime import datetime
import subprocess
import sys
import time


def main() -> int:
    start = time.perf_counter()
    started_at = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    print(f"[pre-commit] {started_at} - Running pytest...", flush=True)

    result = subprocess.run(["pytest"])

    elapsed = time.perf_counter() - start
    if result.returncode != 0:
        print(f"[pre-commit] Tests Failed in {elapsed:.1f}s. Commit rejected.", flush=True)
        return 1

    print(f"[pre-commit] Tests Passed in {elapsed:.1f}s.", flush=True)
    return 0


if __name__ == "__main__":
    sys.exit(main())
