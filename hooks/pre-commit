#!/usr/bin/env python
"""Git pre-commit hook: run pytest before allowing commit."""

import subprocess
import sys


def main() -> int:
    result = subprocess.run(
        ["pytest"],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )

    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)

    if result.returncode != 0:
        print("Tests Failed! Commit rejected.")
        return 1

    print("Tests Passed!")
    return 0


if __name__ == "__main__":
    sys.exit(main())
